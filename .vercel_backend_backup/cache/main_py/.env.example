# ============================================================
# LxwyerUp Backend — Environment Variables Template
# Copy this file as .env for local dev.
# Set these as Environment Variables in Vercel for production.
# ============================================================

# MongoDB Atlas connection string (get from atlas.mongodb.com)
MONGO_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Database name
DB_NAME=lxwyerup

# JWT secrets (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRATION_HOURS=8
JWT_ADMIN_EXPIRATION_HOURS=8

# CORS — comma-separated list of allowed frontend origins
# In production, set to your Vercel frontend URL, e.g.:
# CORS_ALLOWED_ORIGINS=https://lxwyerup.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Admin & monitor accounts
ADMIN_EMAIL=admin@lxwyerup.com
ADMIN_PASSWORD=hiadminlawyer1
MONITOR_EMAIL=monitor@lxwyerup.com
MONITOR_PASSWORD=himonitor01

# Admin IP guard — set to * to allow all IPs (required for Vercel serverless)
# Leave as default (127.0.0.1,::1) for local dev only
ADMIN_ALLOWED_IPS=127.0.0.1,::1,localhost

# Brute-force lockout settings
MAX_LOGIN_ATTEMPTS=10
LOGIN_WINDOW_SECS=300
LOGIN_LOCKOUT_SECS=900

# Google OAuth Client ID (public, safe to share)
GOOGLE_CLIENT_ID=273397136186-pglrchd1ivrhjrff5ghp29hpnbncshvk.apps.googleusercontent.com
